# =============================================================================
# .gitignore — Tells Git which files to NEVER track or commit
# =============================================================================
# Rule: if a file is in .gitignore, git add / git commit will completely
# ignore it — it won't show up in `git status` and can't be committed.
#
# Why this matters:
#   - API keys MUST never be committed (security risk)
#   - Generated files don't belong in version control (they're reproducible)
#   - Large binary files (model weights, vector indexes) bloat the repo
# =============================================================================


# -----------------------------------------------------------------------------
# SECRETS — The most important section. Never commit these.
# -----------------------------------------------------------------------------

# .env holds your ANTHROPIC_API_KEY and any other secrets
# We commit .env.example (the template) but never the real .env
.env
.env.local
.env.*.local


# -----------------------------------------------------------------------------
# GENERATED DATA — Auto-created at runtime, not source code
# -----------------------------------------------------------------------------

# The vector index (vectors.npz + chunks.json) is generated by `python main.py --index`
# It can be re-created anytime — no need to store it in git
# Also, it can be large (MBs to GBs depending on your document set)
storage/


# -----------------------------------------------------------------------------
# PYTHON — Standard Python project ignores
# -----------------------------------------------------------------------------

# Compiled Python files (auto-generated by Python interpreter)
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Python package build artifacts
*.egg-info/
dist/
build/
*.egg

# Virtual environment directories (each developer creates their own)
.venv/
venv/
env/
ENV/
.virtualenv/

# pytest cache
.pytest_cache/
.coverage
htmlcov/

# mypy type checker cache
.mypy_cache/


# -----------------------------------------------------------------------------
# AI / ML — Large model files
# -----------------------------------------------------------------------------

# Sentence transformer model cache (~80MB+, downloaded automatically)
# Don't commit model weights — they're downloaded from HuggingFace on first run
*.cache/
model_cache/
models/


# -----------------------------------------------------------------------------
# DOCKER — Local Docker artifacts
# -----------------------------------------------------------------------------

# Docker override files (local dev customizations)
docker-compose.override.yml


# -----------------------------------------------------------------------------
# IDEs AND EDITORS
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml

# Vim/Neovim
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace


# -----------------------------------------------------------------------------
# OPERATING SYSTEM
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
