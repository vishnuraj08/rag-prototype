# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your values in .env
#   3. NEVER commit .env — it's in .gitignore for a reason
#
# WHY ENV VARIABLES?
#   Hardcoding secrets (API keys, passwords) in source code is dangerous.
#   If you push to GitHub, anyone can see them.
#   Environment variables keep secrets OUT of your code.
#
# For Docker:   docker-compose reads .env automatically
# For local:    run `export $(cat .env | xargs)` or use python-dotenv
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — Your Anthropic API key
# Get it from: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here


# -----------------------------------------------------------------------------
# OPTIONAL — Override config.py defaults without editing code
# Uncomment and set any of these to customize behaviour
# -----------------------------------------------------------------------------

# Which LLM model to use for answer generation (maps to LLM_MODEL in config.py)
# LLM_MODEL=claude-sonnet-4-6

# Number of chunks to retrieve per query
# TOP_K=3

# Minimum similarity score threshold (0.0 to 1.0)
# MIN_SIMILARITY_SCORE=0.2

# Characters per chunk when indexing documents
# CHUNK_SIZE=500

# Character overlap between consecutive chunks
# CHUNK_OVERLAP=50
