# =============================================================================
# .dockerignore — Files to EXCLUDE from the Docker build context
# =============================================================================
#
# WHAT IS THE BUILD CONTEXT?
#   When you run `docker build .`, Docker sends ALL files in the current
#   directory to the Docker daemon. This is called the "build context".
#   Large contexts = slow builds.
#
# .dockerignore tells Docker: "don't include these files in the context".
# Similar to .gitignore but for Docker builds.
#
# Even if you COPY . . in your Dockerfile, files listed here are excluded.
# =============================================================================

# Git history — not needed inside the container
.git
.gitignore

# Environment files — secrets must never go inside an image!
# Pass them at runtime via --env-file or -e flags
.env
.env.*

# Python cache — will be regenerated inside the container
__pycache__
*.py[cod]
*.pyo

# Virtual environments — the container has its own Python
.venv
venv
env

# The vector index — this is runtime data, not build-time data
# It's mounted as a volume (see docker-compose.yml)
storage/

# Documentation — not needed to run the app
*.md
!README.md

# IDE and OS files
.vscode
.idea
.DS_Store
Thumbs.db

# Docker files themselves
docker-compose.override.yml
